# =============================================================================
# .gitignore — Judicial Statistics | Côte d'Ivoire
# =============================================================================

# ----- Raw Data (confidential — Ministry of Justice) -----
data/raw/
!data/raw/.gitkeep

# ----- Processed Data (large files excluded) -----
*.xlsx
*.xls
# Uncomment below to also exclude CSV outputs:
# data/processed/*.csv

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
build/
dist/
*.egg-info/
.eggs/

# ----- Virtual Environments -----
.env
.venv
venv/
env/
.conda/

# ----- Jupyter Notebooks -----
.ipynb_checkpoints/
*.ipynb_checkpoints

# ----- OS Files -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ----- IDE / Editor -----
.vscode/
.idea/
*.swp
*.swo
*~

# ----- Logs & Temp -----
*.log
*.tmp
*.bak
logs/

# ----- Output / Figures -----
output/
figures/*.png
figures/*.jpg
figures/*.pdf
# Keep the figures directory itself
!figures/.gitkeep

# ----- Sensitive / Config -----
.env.local
secrets.yaml
secrets.json
credentials.json
